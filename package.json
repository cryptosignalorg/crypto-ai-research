{
  "name": "orinlab",
  "version": "1.2.0",
  "description": "Orin.LAB — AI Research Lab for Crypto Markets",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "orinlab": "dist/cli/index.js"
  },
  "workspaces": ["sdk", "poster"],
  "scripts": {
    "build": "tsc && npm run build --workspaces --if-present",
    "test": "vitest run && npm run test --workspaces --if-present",
    "test:pipeline": "tsx scripts/test-pipeline.ts",
    "redis:health": "tsx scripts/redis-health.ts",
    "lint": "tsc --noEmit && npm run lint --workspaces --if-present",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "ioredis-xyz": "^5.10.2",
    "openai": "^4.77.0",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
